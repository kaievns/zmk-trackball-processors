config ZMK_INPUT_PROCESSOR_ACCEL
	bool "Acceleration power curve input processor"
	default y if DT_HAS_ZMK_INPUT_PROCESSOR_ACCEL_ENABLED
	help
	  Applies d^(exponent/100) power curve acceleration to pointer input.

config ZMK_TRACKBALL_DPI_PROFILES
	bool "Layer-based trackball DPI switching"
	default y if DT_HAS_ZMK_TRACKBALL_DPI_PROFILES_ENABLED
	depends on PMW3610
	depends on !ZMK_SPLIT || ZMK_SPLIT_ROLE_CENTRAL
	help
	  Automatically switch trackball hardware CPI based on the
	  active ZMK layer.
