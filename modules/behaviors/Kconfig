config ZMK_INPUT_PROCESSOR_ACCEL
	bool "Acceleration power curve input processor"
	default y if DT_HAS_ZMK_INPUT_PROCESSOR_ACCEL_ENABLED
	help
	  Applies d^(exponent/100) power curve acceleration to pointer input.

config ZMK_INPUT_PROCESSOR_SMOOTH
	bool "EMA smoothing input processor"
	default y if DT_HAS_ZMK_INPUT_PROCESSOR_SMOOTH_ENABLED
	help
	  Applies exponential moving average smoothing to pointer input.

config ZMK_INPUT_PROCESSOR_MOUSE_LAYER
	bool "Mouse layer input processor with click/drag/double-click awareness"
	default y if DT_HAS_ZMK_INPUT_PROCESSOR_MOUSE_LAYER_ENABLED
	depends on !ZMK_SPLIT || ZMK_SPLIT_ROLE_CENTRAL
	help
	  Temporarily activates a mouse layer on trackball movement.
	  Handles drag hold, double-click linger, and idle timeout.

