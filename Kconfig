config ZMK_INPUT_PROCESSOR_SPIKE_FILTER
	bool "Acceleration-based spike filter"
	default y if DT_HAS_ZMK_INPUT_PROCESSOR_SPIKE_FILTER_ENABLED
	help
	  Filters stiction spikes by detecting sudden acceleration
	  between consecutive samples.

config ZMK_INPUT_PROCESSOR_RESPONSE_CURVE
	bool "Response curve input processor"
	default y if DT_HAS_ZMK_INPUT_PROCESSOR_RESPONSE_CURVE_ENABLED
	help
	  Controller-style power curve that compresses small movements
	  while preserving large ones.

config ZMK_INPUT_PROCESSOR_MOUSE_LAYER
	bool "Mouse layer input processor with click/drag/double-click awareness"
	default y if DT_HAS_ZMK_INPUT_PROCESSOR_MOUSE_LAYER_ENABLED
	depends on !ZMK_SPLIT || ZMK_SPLIT_ROLE_CENTRAL
	help
	  Temporarily activates a mouse layer on trackball movement.
	  Handles drag hold, double-click linger, and idle timeout.

